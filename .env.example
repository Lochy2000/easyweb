# Copy this file to .env and fill in real values for local development.
# In production these are set in the Vercel dashboard (Project Settings -> Environment Variables).

# Postgres connection string. Auto-populated in Vercel once you provision
# Postgres from the project's Storage tab and link it — copy that value here
# for local dev (or run `vercel env pull .env` after linking).
POSTGRES_URL=

# Password for the single /admin login. Pick a long random value.
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie (JWT). Pick a long random value
# (e.g. `openssl rand -base64 32`) — do not reuse ADMIN_PASSWORD for this.
SESSION_SECRET=
